---
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import "@fontsource-variable/inter";
import "@fontsource-variable/jetbrains-mono";
import "../styles/global.css";
interface Props { title?: string; }
const { title = "curiousapple" } = Astro.props;
const description =
  "Smart contract security audit portfolio of curiousapple — Lead Security Researcher @ Guardian, ex-0xMacro.";
const og = new URL("/og-v2.png", Astro.site).href;
const canonical = new URL(Astro.url.pathname, Astro.site).href;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  mainEntity: {
    "@type": "Person",
    name: "curiousapple",
    alternateName: "0xcuriousapple",
    url: "https://curiousapple.xyz",
    image: og,
    jobTitle: "Cybersecurity Researcher and Consultant",
    description,
    worksFor: { "@type": "Organization", name: "Guardian", url: "https://guardianaudits.com/" },
    knowsAbout: [
      "Smart Contract Security",
      "Solidity",
      "DeFi",
      "Derivatives",
      "Automated Market Makers",
      "Lending Protocols",
      "Vaults",
      "Cross-chain Bridges",
      "Stablecoins",
      "Account Abstraction",
    ],
    sameAs: [
      "https://x.com/0xcuriousapple",
      "https://github.com/0xcuriousapple",
      "https://t.me/curiousapple",
    ],
  },
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#0a0a0b" />

    <!-- Apply saved theme before paint to avoid flash -->
    <script is:inline>
      (() => {
        const saved = localStorage.getItem("theme");
        const dark = saved ? saved === "dark" : true;
        document.documentElement.classList.toggle("light", !dark);
      })();
    </script>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={og} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={og} />
    <meta name="twitter:creator" content="@0xcuriousapple" />

    <!-- Structured data -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <slot />
    <Analytics />
    <SpeedInsights />
  </body>
</html>
